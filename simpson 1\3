#include <iostream>
#include <string>
#include <cmath>
#include <iomanip>
#include <algorithm>
#include <stdexcept>

using namespace std;

class MathParser {
    string expr;
    size_t pos;
    double x_val;

    double parsePrimary() {
        if (pos >= expr.length()) return 0;

        char ch = expr[pos];

        if (ch == 'x' || ch == 'X') {
            pos++;
            return x_val;
        }

        if (ch == '(') {
            pos++;
            double res = parseAddSub();
            if (pos < expr.length() && expr[pos] == ')')
                pos++;
            return res;
        }

        size_t start = pos;
        while (pos < expr.length() &&
               (isdigit(expr[pos]) || expr[pos] == '.'))
            pos++;

        if (start == pos)
            throw runtime_error("Error");

        return stod(expr.substr(start, pos - start));
    }

    double parseExponent() {
        double left = parsePrimary();

        while (pos < expr.length() && expr[pos] == '^') {
            pos++;
            double right = parseUnary();
            left = pow(left, right);
        }

        return left;
    }

    double parseUnary() {
        if (pos >= expr.length()) return 0;

        if (expr[pos] == '+') {
            pos++;
            return parseUnary();
        }

        if (expr[pos] == '-') {
            pos++;
            return -parseUnary();
        }

        return parseExponent();
    }

    double parseMulDiv() {
        double left = parseUnary();

        while (pos < expr.length() &&
              (expr[pos] == '*' || expr[pos] == '/')) {

            char op = expr[pos++];
            double right = parseUnary();

            if (op == '*')
                left *= right;
            else {
                if (right == 0)
                    left = NAN;
                else
                    left /= right;
            }
        }

        return left;
    }

    double parseAddSub() {
        double left = parseMulDiv();

        while (pos < expr.length() &&
              (expr[pos] == '+' || expr[pos] == '-')) {

            char op = expr[pos++];
            double right = parseMulDiv();

            if (op == '+')
                left += right;
            else
                left -= right;
        }

        return left;
    }

public:
    double evaluate(string expression, double x) {
        expr = expression;

        expr.erase(
            remove_if(expr.begin(), expr.end(), ::isspace),
            expr.end()
        );

        pos = 0;
        x_val = x;

        return parseAddSub();
    }
};

int main() {

    MathParser parser;

    string fungsi;
    double a, b;

    int n;

    cout << "==================================================================" << endl;
    cout << "                    METODE SIMPSON 1/3                            " << endl;
    cout << "==================================================================" << endl;
    cout << "PETUNJUK PENULISAN FUNGSI" << endl;
    cout << "1. Gunakan x sebagai variabel." << endl;
    cout << "2. Gunakan * untuk perkalian." << endl;
    cout << "3. Gunakan ^ untuk pangkat." << endl;
    cout << "4. Contoh:" << endl;
    cout << "   x^2" << endl;
    cout << "   3*x+2" << endl;
    cout << "   (x^3+2*x)/(x+1)" << endl;
    cout << "==================================================================" << endl;

    cout << "Masukkan fungsi f(x): ";
    getline(cin, fungsi);

    cout << "Masukkan batas bawah (a): ";
    cin >> a;

    cout << "Masukkan batas atas (b): ";
    cin >> b;

    cout << "Masukkan jumlah interval n (genap): ";
    cin >> n;

    if (n % 2 != 0) {
        cout << "\nERROR: n harus genap!" << endl;
        return 1;
    }

    double h = (b - a) / n;

    cout << "\n==================================================================" << endl;
    cout << setw(5)  << "i"
         << setw(15) << "x_i"
         << setw(15) << "f(x_i)"
         << setw(15) << "Bobot"
         << setw(15) << "Bobot*f(x)"
         << endl;

    cout << "==================================================================" << endl;

    double sum = 0;

    for (int i = 0; i <= n; i++) {

        double x = a + i * h;

        double fx;

        try {
            fx = parser.evaluate(fungsi, x);
        }
        catch (...) {
            cout << "Fungsi tidak valid!" << endl;
            return 1;
        }

        int bobot;

        if (i == 0 || i == n)
            bobot = 1;
        else if (i % 2 == 1)
            bobot = 4;
        else
            bobot = 2;

        sum += bobot * fx;

        cout << fixed << setprecision(6);

        cout << setw(5)  << i
            << setw(15) << x
            << setw(15) << fx
            << setw(15) << bobot
             << setw(15) << bobot * fx
            << endl;
    }

    double integral = (h / 3.0) * sum;

    cout << "==================================================================" << endl;

    cout << "\nNilai h = " << h << endl;

    cout << "Integral = " << integral << endl;

    cout << "\n==================================================================" << endl;

    return 0;
}
